{
  "name": "job-fit-analyzer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:mcp": "npm run build -w @jfa/mcp-server",
    "dev:server": "npm run dev -w @jfa/server",
    "dev:web": "npm run dev -w @jfa/web",
    "dev": "npm run build:mcp && concurrently -n server,web -c blue,magenta \"npm:dev:server\" \"npm:dev:web\""
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
